@page "/qr-scanner"
@using HostelMS.Blazor.Services
@using HostelMS.Blazor.Models
@attribute [Authorize]
@inject IAttendanceApiService AttSvc
@inject IStudentApiService StudentSvc

<PageTitle>QR Scanner - HostelMS</PageTitle>

<div class="page-content">
    <div style="max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:20px">

        <!-- Scanner Card -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">📱 QR Code Scanner</span>
                <span style="font-size:12px;color:var(--text-secondary)">Scan or enter student token for attendance</span>
            </div>
            <div class="card-body">
                <div style="background:var(--gradient);border-radius:var(--radius);padding:32px;text-align:center;margin-bottom:20px;position:relative;overflow:hidden">
                    <div style="font-size:64px;margin-bottom:12px">📱</div>
                    <h3 style="color:#fff;font-weight:700;margin-bottom:6px">Scan QR Code</h3>
                    <p style="color:rgba(255,255,255,.8);font-size:13px">Point camera at student QR code<br/>or copy token from student profile below</p>
                    <div style="position:absolute;inset:16px;border:2px dashed rgba(255,255,255,0.35);border-radius:10px;pointer-events:none"></div>
                </div>

                <div style="background:var(--surface-2);border-radius:var(--radius-sm);padding:20px;border:1px solid var(--border)">
                    <div style="font-weight:700;font-size:14px;margin-bottom:12px">Manual Token Entry</div>
                    <div class="form-group">
                        <label class="form-label">Paste QR Token here</label>
                        <textarea @bind="_token" class="form-control" rows="3" placeholder="Paste the base64 token from student profile..."></textarea>
                    </div>
                    <div style="display:flex;gap:10px">
                        <button class="btn btn-primary" style="flex:1;justify-content:center"
                                @onclick='() => ScanEntry("In")' disabled="@string.IsNullOrWhiteSpace(_token)">
                            ✅ Mark Entry (IN)
                        </button>
                        <button class="btn btn-warning" style="flex:1;justify-content:center"
                                @onclick='() => ScanEntry("Out")' disabled="@string.IsNullOrWhiteSpace(_token)">
                            🚪 Mark Exit (OUT)
                        </button>
                    </div>
                </div>

                @if (_result != null)
                {
                    <div class="alert alert-success mt-2">
                        <div style="font-size:16px">✅ <strong>@_result.StudentName</strong> marked <strong>@_result.Status</strong></div>
                        <div style="font-size:12px;margin-top:4px;opacity:.8">@_result.StudentRollNo · @(_result.InTime.HasValue ? _result.InTime.Value.ToString("HH:mm") : "")</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger mt-2">⚠️ @_error</div>
                }
            </div>
        </div>

        <!-- Generate Token for Student -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">🔑 Get Student Token</span>
                <span style="font-size:12px;color:var(--text-secondary)">Generate today's token for a student</span>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Select Student</label>
                    <select @bind="_selStudentId" class="form-control" @bind:after="GenerateToken">
                        <option value="0">-- Select Student --</option>
                        @foreach (var s in _students)
                        {
                            <option value="@s.Id">@s.FullName (@s.StudentId)</option>
                        }
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(_generatedToken))
                {
                    <div style="background:var(--surface-2);border-radius:8px;padding:14px;border:1px solid var(--border);margin-top:8px">
                        <div style="font-size:12px;color:var(--text-secondary);margin-bottom:6px;font-weight:600">TODAY'S TOKEN (valid until midnight):</div>
                        <div style="font-family:monospace;font-size:11px;word-break:break-all;color:var(--primary);background:var(--surface-3);padding:10px;border-radius:6px">@_generatedToken</div>
                        <button class="btn btn-secondary btn-sm mt-1" @onclick="CopyToken">📋 Copy Token</button>
                        <button class="btn btn-primary btn-sm mt-1" style="margin-left:8px" @onclick="UseToken">⬆️ Use This Token</button>
                    </div>

                    @if (!string.IsNullOrEmpty(_selectedStudentQR))
                    {
                        <div style="text-align:center;margin-top:16px">
                            <div style="font-size:12px;color:var(--text-secondary);margin-bottom:8px;font-weight:600">QR CODE IMAGE:</div>
                            <img src="@_selectedStudentQR" style="width:160px;height:160px;border-radius:8px;border:2px solid var(--border)" alt="QR Code"/>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Recent Scans -->
        @if (_scans.Any())
        {
            <div class="card">
                <div class="card-header"><span class="card-title">🕐 Recent Scans Today</span></div>
                <div class="table-wrapper">
                    <table class="table">
                        <thead><tr><th>Student</th><th>Type</th><th>Status</th><th>Time</th></tr></thead>
                        <tbody>
                            @foreach (var s in _scans)
                            {
                                <tr>
                                    <td><div style="font-weight:600">@s.StudentName</div><div style="font-size:11px;color:var(--text-secondary)">@s.StudentRollNo</div></td>
                                    <td><span class="badge badge-purple">@s.Type</span></td>
                                    <td><span class="badge badge-success">@s.Status</span></td>
                                    <td>@(s.InTime.HasValue ? s.InTime.Value.ToString("HH:mm:ss") : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string _token = "";
    private AttendanceDto? _result;
    private string _error = "";
    private List<AttendanceDto> _scans = new();
    private List<StudentDto> _students = new();
    private int _selStudentId;
    private string _generatedToken = "";
    private string _selectedStudentQR = "";

    protected override async Task OnInitializedAsync()
    {
        _students = await StudentSvc.GetAllAsync();
    }

    async Task ScanEntry(string type)
    {
        if (string.IsNullOrWhiteSpace(_token)) return;
        _result = null; _error = "";
        var r = await AttSvc.QRScanAsync(_token.Trim(), type);
        if (r != null)
        {
            _result = r;
            _scans.Insert(0, r);
            if (_scans.Count > 10) _scans.RemoveAt(_scans.Count - 1);
            _token = "";
        }
        else
        {
            _error = "Invalid or expired token. Please regenerate the student token and try again.";
        }
    }

    async Task GenerateToken()
    {
        if (_selStudentId == 0) { _generatedToken = ""; return; }
        var student = _students.FirstOrDefault(s => s.Id == _selStudentId);
        if (student == null) return;

        // Call API to get fresh token
        var qr = await StudentSvc.RegenerateQRAsync(_selStudentId);
        _selectedStudentQR = qr ?? "";

        // Generate today's attendance token
        var secret = "HostelMS_SuperSecret_JWT_Key_2024_Min32Chars!!";
        var raw = $"{_selStudentId}:{DateTime.UtcNow:yyyyMMdd}:{secret}";
        var hash = Convert.ToBase64String(
            System.Security.Cryptography.SHA256.HashData(
                System.Text.Encoding.UTF8.GetBytes(raw)));
        var token = $"{_selStudentId}:{DateTime.UtcNow:yyyyMMdd}:{hash}";
        _generatedToken = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(token));
    }

    void UseToken() { _token = _generatedToken; }

    async Task CopyToken()
    {
        // Copy to clipboard via JS interop would go here
        // For now just populate the token field
        _token = _generatedToken;
    }
}
